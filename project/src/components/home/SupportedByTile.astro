---
/**
 * SupportedByTile — Bento grid tile showing the DIBRIS UniGe logo.
 */
---

<div class="info-card tile-supported accent-teal">
  <div class="card-content centered-content">
    <h3>Supported By</h3>
    <div class="supported-image-wrapper">
      <img src="/UniGe_white.png" alt="DIBRIS UniGe Logo" class="supported-img" />
    </div>
  </div>
</div>

<style>
  .tile-supported {
    grid-column: span 1;
    grid-row: span 1;
    display: flex;
    flex-direction: column;
  }

  .supported-image-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 20px 0;
  }

  .supported-img {
    max-width: 100%;
    max-height: 80px;
    object-fit: contain;
  }
</style>
