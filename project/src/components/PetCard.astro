---
export interface Props {
  name: string;
  info?: string;
  photo: string;
  tags: string[];
}

const { name, info, photo, tags } = Astro.props;

const tagColors: Record<string, string> = {
  dog: "var(--accent-teal)",
  cat: "var(--accent-pink)",
  bird: "var(--accent-blue)",
  reptile: "var(--accent-green)",
  fish: "var(--accent-orange)",
  mammal: "var(--accent-gold)",
  exotic: "linear-gradient(135deg, #ff416c, #8b00ff, #00eaff)",
  'wild-boar': "var(--accent-orange)"
};

const firstTag = tags && tags.length > 0 ? tags[0].toLowerCase().replace(/\s+/g, '-') : '';
const cardAccent = tagColors[firstTag] || "var(--accent-teal)";
---

<div class="pet-card" style={`--card-accent: ${cardAccent};`}>
  <img src={photo} alt={name} class="pet-photo">
  <div class="pet-name">{name}</div>
  <div class="pet-info">{info || ""}</div>
  <div class="pet-tags">
    {tags.map(tag => (
      <span class={`tag ${tag.toLowerCase().replace(/\s+/g, '-')}`}>{tag}</span>
    ))}
  </div>
</div>

<style>
  .pet-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-top: 3px solid var(--card-accent);
    border-radius: 4px;
    padding: 30px;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 320px;
    height: 100%;
    width: 100%;
    cursor: default;
  }

  .pet-card:hover {
    border-color: var(--card-accent);
  }

  .pet-photo {
    width: 120px;
    height: 120px;
    border-radius: 4px;
    object-fit: cover;
    margin: 0 auto 20px;
    display: block;
    flex-shrink: 0;
  }

  .pet-name {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .pet-info {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 15px;
    min-height: 24px;
    flex-shrink: 0;
  }

  .pet-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-top: auto;
  }

  .tag {
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 500;
  }
</style>