---
export interface Props {
  post: {
    url: string;
    isLocal: boolean;
    frontmatter: {
      author: string;
      date: string;
      title: string;
      tags?: string[];
    };
  };
}

const { post } = Astro.props;
---

<article class={`post-card ${post.isLocal ? '' : 'member-post'}`}>
  <div class="post-content">
    <div class="post-meta">
      <span class="post-author">by {post.frontmatter.author}</span>
      <span class="post-date">{new Date(post.frontmatter.date).toLocaleDateString('it-IT')}</span>
    </div>
    <h2 class="post-title">
      <a href={post.url} target={post.isLocal ? '_self' : '_blank'} rel={post.isLocal ? '' : 'noopener noreferrer'}>
        {post.frontmatter.title}
        {!post.isLocal && <span class="external-icon"> ↗</span>}
      </a>
    </h2>
    <div class="post-tags">
      {!post.isLocal && <span class="tag external">External</span>}
      {(post.frontmatter.tags || []).map((tag: string) => (
        <span class={`tag ${tag.toLowerCase().replace(/\s+/g, '-')}`}>{tag}</span>
      ))}
    </div>
    <a href={post.url} target={post.isLocal ? '_self' : '_blank'} rel={post.isLocal ? '' : 'noopener noreferrer'} class="read-more">
      {post.isLocal ? 'Read more →' : `Read on ${post.frontmatter.author}'s blog →`}
    </a>
  </div>
</article>

<style>
  .post-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-top: 3px solid var(--accent-green);
    border-radius: 4px;
    overflow: hidden;
    backdrop-filter: blur(10px);
    transition: all 0.2s ease;
  }

  .post-card.member-post {
    border: 1px solid var(--accent-teal);
    border-top: 3px solid var(--accent-teal);
    box-shadow: none;
  }

  .external-icon {
    margin-left: 4px;
    font-size: 0.9em;
  }

  .tag.external {
    background: var(--accent-teal);
    color: var(--bg-primary);
    font-weight: 600;
  }

  .post-card:hover {
    border-color: var(--text-secondary);
    border-top-color: var(--accent-gold);
    box-shadow: none;
    transform: none;
  }

  .post-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .post-card:hover .post-image img {
    transform: scale(1.05);
  }

  .post-content {
    padding: 25px;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .post-title {
    margin-bottom: 15px;
  }

  .post-title a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .post-title a:hover {
    color: var(--accent-gold);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .tag {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    color: white;
  }

  .read-more {
    color: var(--accent-teal);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .read-more:hover {
    color: var(--accent-gold);
  }

  @media (max-width: 768px) {
    .post-meta {
      flex-direction: column;
      gap: 5px;
    }
  }
</style>
