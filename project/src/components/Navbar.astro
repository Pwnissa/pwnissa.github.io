---
import { navLinks, NAV_BRAND } from '../consts';
---

<nav id="navbar" class="navbar">
    <div class="navbar-container">
      <div class="navbar-brand">
        <a href="/">{NAV_BRAND}</a>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
      <div class="navbar-menu" id="navbar-menu">
        {navLinks.map(link => (
          link.subLinks ? (
            <div class="nav-item-dropdown">
              <button class="navbar-link dropdown-toggle" aria-haspopup="true" aria-expanded="false">
                {link.name}
                <svg class="dropdown-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
              <div class="dropdown-menu">
                {link.subLinks.map(subLink => (
                  <a href={subLink.href} class="dropdown-link" target={subLink.href.startsWith('http') ? '_blank' : '_self'}>{subLink.name}</a>
                ))}
              </div>
            </div>
          ) : (
            <a href={link.href} class="navbar-link" target={link.href.startsWith('http') ? '_blank' : '_self'}>{link.name}</a>
          )
        ))}
      </div>
    </div>
  </nav>
  
  <script>
    window.addEventListener('load', () => {
        const navbar = document.getElementById('navbar');
        navbar?.classList.add('visible');
        
        const hamburger = document.getElementById('hamburger');
        const menu = document.getElementById('navbar-menu');
        
        hamburger?.addEventListener('click', () => {
            hamburger.classList.toggle('is-active');
            menu?.classList.toggle('is-open');
        });

        // Mobile dropdown toggles
        const dropdownToggles = document.querySelectorAll('.dropdown-toggle');
        dropdownToggles.forEach(toggle => {
            toggle.addEventListener('click', (e) => {
                if (window.innerWidth <= 768) {
                    e.preventDefault();
                    const parent = toggle.parentElement;
                    parent?.classList.toggle('is-active');
                    const expanded = toggle.getAttribute('aria-expanded') === 'true' || false;
                    toggle.setAttribute('aria-expanded', (!expanded).toString());
                }
            });
        });
    });
  </script>
  
  <style>
    
    a, button {
      -webkit-tap-highlight-color: transparent;
    }

    .navbar {
      position: fixed;
      top: 20px;
      left: 0;
      right: 0;
      margin: 0 auto;
      width: calc(100% - 20px);
      max-width: 1080px;
      z-index: 1000;
      border-radius: 4px;
      transition: transform 0.3s ease-in-out;
    }
    
    .navbar::before {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(10, 10, 10, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      z-index: -1;
      transition: background 0.3s ease-in-out;
    }
  
    .navbar.visible {
      transform: translateY(0);
    }
  
    .navbar-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 60px;
    }
  
    .navbar-brand a {
      font-family: 'PwnissaLogoFont', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      text-decoration: none;
      background: var(--accent-gold);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      transition: all 0.3s ease;
    }
  
    .navbar-brand a:hover {
      filter: brightness(1.2);
    }
  
    .navbar-menu {
      display: flex;
      gap: 30px;
      align-items: center;
    }
  
    .navbar-link {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      padding: 8px 16px;
      border-radius: 8px;
      transition: all 0.3s ease;
      position: relative;
      background: none;
      border: none;
      font-family: inherit;
      font-size: 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 5px;
    }
  
    .navbar-link:hover {
      color: var(--accent-gold);
      background: rgba(237, 192, 30, 0.1);
    }
  
    .navbar-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      background: var(--accent-gold);
      transition: all 0.3s ease;
      transform: translateX(-50%);
    }
  
    .navbar-link:not(.dropdown-toggle):hover::after,
    .nav-item-dropdown:hover > .navbar-link::after {
      width: 80%;
    }

    .nav-item-dropdown:hover > .navbar-link {
      color: var(--accent-gold);
      background: rgba(237, 192, 30, 0.1);
    }

    .dropdown-icon {
      transition: transform 0.3s ease;
    }

    /* Dropdown Desktop */
    .nav-item-dropdown {
      position: relative;
    }

    .dropdown-menu {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(10px);
      background: rgba(15, 15, 15, 0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 10px 0;
      min-width: 200px;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .nav-item-dropdown:hover .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(5px);
    }

    .nav-item-dropdown:hover .dropdown-icon {
      transform: rotate(180deg);
    }

    .dropdown-link {
      display: block;
      padding: 10px 20px;
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s ease;
      text-align: center;
    }

    .dropdown-link:hover {
      color: var(--accent-gold);
      background: rgba(255, 255, 255, 0.05);
    }
  
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 5px;
      z-index: 1001;
    }

    .hamburger span {
      display: block;
      width: 25px;
      height: 2px;
      background-color: var(--text-primary);
      transition: all 0.3s ease;
    }

    .hamburger.is-active span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .hamburger.is-active span:nth-child(2) {
      opacity: 0;
    }
    .hamburger.is-active span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    @media (max-width: 768px) {
      .navbar-container {
        padding: 0 15px;
      }
      
      .navbar-brand a {
        font-size: 1.3rem;
      }
      
      .hamburger {
        display: flex;
      }

      .navbar-menu {
        position: absolute;
        top: calc(100% + 10px);
        left: 0;
        right: 0;
        background: rgba(10, 10, 10, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        flex-direction: column;
        align-items: stretch;
        padding: 10px 0;
        gap: 0;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        
        /* Mobile closed state */
        transform: translateY(-10px);
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s ease;
        z-index: -1;
      }

      .navbar-menu.is-open {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
        display: flex;
      }

      .navbar-link {
        text-align: left;
        width: 100%;
        box-sizing: border-box;
        padding: 15px 20px;
        border-radius: 0;
        justify-content: space-between;
      }

      .navbar-link::after {
        display: none;
      }

      /* Dropdown Mobile */
      .dropdown-menu {
        position: static;
        transform: none;
        background: rgba(0,0,0,0.2);
        box-shadow: inset 0 3px 6px rgba(0,0,0,0.2);
        border: none;
        border-radius: 0 0 8px 8px;
        padding: 0;
        min-width: 100%;
        max-height: 0;
        overflow: hidden;
        border-left: 2px solid var(--accent-gold);
        margin-left: 20px;
        width: calc(100% - 20px);
        box-sizing: border-box;
        opacity: 1;
        visibility: visible;
        transition: max-height 0.3s ease-out, padding 0.3s ease;
      }

      .nav-item-dropdown:hover .dropdown-menu {
        transform: none; 
      }

      .nav-item-dropdown.is-active .dropdown-menu {
        max-height: 200px;
        padding: 10px 0;
      }

      .nav-item-dropdown.is-active .dropdown-icon {
        transform: rotate(180deg);
      }

      .dropdown-link {
        text-align: left;
        padding: 12px 20px;
      }
    }
  </style>