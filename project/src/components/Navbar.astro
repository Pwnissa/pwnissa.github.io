---
import { navLinks, NAV_BRAND } from '../consts';
---

<nav id="navbar" class="navbar">
    <div class="navbar-container">
      <div class="navbar-brand">
        <a href="/">{NAV_BRAND}</a>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
      <div class="navbar-menu" id="navbar-menu">
        {navLinks.map(link => (
          <a href={link.href} class="navbar-link" target={link.href.startsWith('http') ? '_blank' : '_self'}>{link.name}</a>))}
      </div>
    </div>
  </nav>
  
  <script>
    // Since the hero-fullscreen was removed, the navbar should always be visible.
    // We add a class on load just to ensure transitions play if needed.
    window.addEventListener('load', () => {
        const navbar = document.getElementById('navbar');
        navbar?.classList.add('visible');
        
        const hamburger = document.getElementById('hamburger');
        const menu = document.getElementById('navbar-menu');
        
        hamburger?.addEventListener('click', () => {
            hamburger.classList.toggle('is-active');
            menu?.classList.toggle('is-open');
        });
    });
  </script>
  
  <style>
    
    a{
      -webkit-tap-highlight-color: transparent;  /* added to prevent tap highlight on mobile */
    }

    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      /* Removed transform translateY(-100%) so it is visible by default */
      transition: background 0.3s ease-in-out;
    }
  
    .navbar.visible {
      transform: translateY(0);
    }
  
    .navbar-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 60px;
    }
  
    .navbar-brand a {
      font-family: 'PwnissaLogoFont', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      text-decoration: none;
      background: var(--accent-gold);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      transition: all 0.3s ease;
    }
  
    .navbar-brand a:hover {
      filter: brightness(1.2);
    }
  
    .navbar-menu {
      display: flex;
      gap: 30px;
    }
  
    .navbar-link {
      color: var(--text-secondary);
      text-decoration: none;
      font-weight: 500;
      padding: 8px 16px;
      border-radius: 8px;
      transition: all 0.3s ease;
      position: relative;
      
    }
  
    .navbar-link:hover {
      color: var(--accent-gold);
      background: rgba(237, 192, 30, 0.1);
    }
  
    .navbar-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      background: var(--accent-gold);
      transition: all 0.3s ease;
      transform: translateX(-50%);
    }
  
    .navbar-link:hover::after {
      width: 80%;
    }
  
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 5px;
      z-index: 1001;
    }

    .hamburger span {
      display: block;
      width: 25px;
      height: 2px;
      background-color: var(--text-primary);
      transition: all 0.3s ease;
    }

    .hamburger.is-active span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .hamburger.is-active span:nth-child(2) {
      opacity: 0;
    }
    .hamburger.is-active span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    @media (max-width: 768px) {
      .navbar-container {
        padding: 0 15px;
      }
      
      .navbar-brand a {
        font-size: 1.3rem;
      }
      
      .hamburger {
        display: flex;
      }

      .navbar-menu {
        position: absolute;
        top: 60px;
        left: 0;
        right: 0;
        background: rgba(10, 10, 10, 0.98);
        backdrop-filter: blur(10px);
        flex-direction: column;
        align-items: center;
        padding: 20px 0;
        gap: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        
        /* Mobile closed state */
        transform: translateY(-150%);
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s ease;
        z-index: -1;
      }

      .navbar-menu.is-open {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }
    }
  </style>