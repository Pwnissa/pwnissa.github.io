---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE } from "../consts";
import { getSortedPosts } from '../lib/posts';
import { members } from '../config';

const sortedPosts = await getSortedPosts();

const latestPosts = sortedPosts.slice(0, 2);
---

<Layout title="Pwnissa | CTF Team">
  <div class="main-content-section">
    <div class="container">
      <div class="bento-grid">
        
        <!-- Tile 1: Logo (2x2) -->
        <div class="info-card tile-logo accent-gold">
          <div class="logo-wrapper">
            <img src="/logo-glitch.webp" alt="CTF Team Logo" class="logo" id="main-glitch-logo" />
          </div>
        </div>

        <!-- Tile 2: About Us (2x1) -->
        <div class="info-card tile-about accent-teal">
          <div class="card-content">
            <h3>About Pwnissa</h3>
            <p>We are the <strong>official Capture the Flag (CTF) hacking team</strong> of the <strong>University of Genoa</strong>. Comprised of Bachelor and Master students united by a shared passion for cybersecurity, we actively test our skills in both national and international competitions.</p>

            <p>We also organize a <strong>bootcamp</strong> in the first semester of university where we teach hacking basics to any student who wants to learn.</p>

            <p>Our name comes from combining <strong>"pwn"</strong> with <strong>"panissa"</strong>, a traditional Ligurian street food made from fried chickpeas.</p>  </div>
        </div>

        <!-- Tile 3: Members (1x1) -->
        <div class="info-card tile-members accent-teal">
          <div class="card-content centered-content">
            <h3>The Team</h3>
            <div class="stat-num">{members.length-2}</div>
            <div class="stat-label">Active Players</div>
            <a href="/members" class="cta-button">See the roster</a>
          </div>
        </div>

        <!-- Tile 4: Blog Posts (2x2) -->
        <div class="info-card tile-blog accent-green">
          <div class="card-content">
            <h3>Latest Writeups</h3>
            <div class="blog-list">
              {latestPosts.map(post => (
                <div class="blog-list-item">
                  <div class="post-meta">
                    <span class="post-date">{new Date(post.frontmatter.date).toLocaleDateString('it-IT')}</span>
                    {post.isLocal ? null : <span class="tag external">External</span>}
                  </div>
                  <a href={post.url} target={post.isLocal ? '_self' : '_blank'} rel={post.isLocal ? '' : 'noopener noreferrer'} class="post-title-link">
                    {post.frontmatter.title}
                  </a>
                </div>
              ))}
            </div>
            <a href="/blog" class="cta-button">View all posts</a>
          </div>
        </div>

        <!-- Tile 5: Pwny (2x1) -->
        <div class="info-card tile-pwny accent-gold">
          <div class="card-content pwny-content">
            <h3>Meet Pwny 🐴</h3>
            <p>Our mascot and the most skilled hacker in the team. Pwny helped us win the <strong>Best Mascot Award</strong> at CyberChallenge.IT 2025!</p>
            <a href="/our-pets" class="cta-button">See all our pets</a>
          </div>
          <div class="pwny-image-wrapper">
            <img src="/immagini_membri/pwny.jpg" alt="Pwny the mascot" class="pwny-img" />
          </div>
        </div>

        <!-- Tile 6: Socials (1x1) -->
        <div class="info-card tile-socials accent-green">
          <div class="card-content centered-content">
            <h3>Connect</h3>
            <div class="social-links-grid">
              <a href="https://github.com/Pwnissa" target="_blank" class="social-link">GitHub</a>
              <a href="https://ctftime.org/team/286280" target="_blank" class="social-link">CTFTime</a>
              <a href="mailto:info@pwnissa.it" class="social-link">Email</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  .hidden {
    display: none;
  }

  .main-content-section {
    padding: 100px 0 20px;
    background: var(--bg-primary);
    min-height: 100vh;
  }

  /* Bento Box Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(240px, auto);
    gap: 20px;
  }

  /* Tile Placements */
  .tile-logo {
    grid-column: span 2;
    grid-row: span 2;
    display: flex;
    align-items: stretch;
    justify-content: center;
  }

  .tile-blog {
    grid-column: span 2;
    grid-row: span 1;
  }

  .tile-about {
    grid-column: span 1;
    grid-row: span 2;
  }

  .tile-members {
    grid-column: span 1;
    grid-row: span 1;
  }

  .tile-socials {
    grid-column: span 1;
    grid-row: span 1;
  }

  .info-card.tile-pwny {
    grid-column: span 2;
    grid-row: span 1;
    flex-direction: row;
    align-items: stretch;
  }

  .pwny-image-wrapper {
    flex: 1;
    max-width: 35%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .pwny-img {
    max-width: 100%;
    max-height: 200px;
    object-fit: contain;
  }

  .logo-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    box-sizing: border-box;
    padding: 20px;
  }
  #main-glitch-logo {
    width: 80%;
    max-width: 400px;
    height: auto;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Shared Card Styles */
  .info-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    border-top: 3px solid var(--accent-teal);
  }

  .card-content {
    padding: 30px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .centered-content {
    align-items: center;
    text-align: center;
  }

  .info-card h3 {
    font-size: 1.6rem;
    color: var(--text-primary);
    margin-bottom: 15px;
  }

  .info-card p {
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 20px;
    font-size: 1rem;
  }

  /* Blog List Styling */
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-bottom: 20px;
    width: 100%;
    flex: 1;
  }

  .blog-list-item {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--card-border);
    padding-bottom: 10px;
  }

  .blog-list-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 5px;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-family: 'JetBrains Mono', monospace;
  }

  .tag.external {
    background: var(--accent-teal);
    color: var(--bg-primary);
    padding: 2px 8px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .post-title-link {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-title-link:hover {
    color: var(--accent-green);
  }

  /* Members & Socials Specifics */
  .stat-num {
    font-size: 3rem;
    font-weight: 700;
    color: var(--accent-teal);
    line-height: 1;
    font-family: 'JetBrains Mono', monospace;
    margin: 10px 0;
  }

  .stat-label {
    color: var(--text-secondary);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 25px;
  }

  .social-links-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: auto 0 0 0;
    width: 100%;
  }

  .social-link {
    display: block;
    padding: 8px;
    background: var(--bg-primary);
    border: 1px solid var(--card-border);
    color: var(--text-primary);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    text-transform: uppercase;
    transition: all 0.2s ease;
    border-radius: 4px;
    outline: none;
  }

  .social-link:hover {
    border-color: var(--accent-green);
    color: var(--accent-green);
  }

  /* Buttons & Links */
  .cta-button {
    display: flex;
    width: 100%;
    box-sizing: border-box;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: var(--bg-primary);
    border: 1px solid var(--card-border);
    border-radius: 4px;
    color: var(--text-primary);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 0.9rem;
    text-transform: uppercase;
    transition: all 0.2s ease;
    margin-top: auto;
    outline: none;
    box-shadow: none;
  }

  .cta-button:hover {
    border-color: var(--text-secondary);
    box-shadow: none;
    transform: none;
  }

  /* Accent Colors */
  .accent-teal { border-top-color: var(--accent-teal); }
  .accent-teal .cta-button:hover { border-color: var(--accent-teal); color: var(--accent-teal); }
  .accent-teal .stat-num { color: var(--accent-teal); }

  .accent-green { border-top-color: var(--accent-green); }
  .accent-green .cta-button:hover { border-color: var(--accent-green); color: var(--accent-green); }

  .accent-gold { border-top-color: var(--accent-gold); }
  .accent-gold .cta-button:hover { border-color: var(--accent-gold); color: var(--accent-gold); }

  /* Mobile Responsiveness */
  @media (max-width: 992px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: minmax(200px, auto);
      grid-auto-flow: dense;
    }
    
    .tile-logo, .tile-blog, .tile-about, .info-card.tile-pwny {
      grid-column: span 2;
    }
    
    .tile-members, .tile-socials {
      grid-column: span 1;
    }

    .info-card.tile-pwny {
      flex-direction: column-reverse;
    }

    .pwny-image-wrapper {
      max-width: 100%;
      height: 250px;
    }
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .tile-logo, .tile-blog, .tile-about, .tile-members, .tile-socials, .info-card.tile-pwny {
      grid-column: span 1;
      grid-row: auto;
    }

    .logo-wrapper {
      width: 100%;
      padding: 40px 0;
    }
    #main-glitch-logo {
      width: 80%;
      max-width: none;
    }
  }
</style>
