---
import Layout from "../layouts/Layout.astro";
import { getSortedPosts } from '../lib/posts';
import { members } from '../config';

import LogoTile from "../components/home/LogoTile.astro";
import AboutTile from "../components/home/AboutTile.astro";
import MembersTile from "../components/home/MembersTile.astro";
import BlogTile from "../components/home/BlogTile.astro";
import TrainingTile from "../components/home/TrainingTile.astro";
import SupportedByTile from "../components/home/SupportedByTile.astro";
import PwnyTile from "../components/home/PwnyTile.astro";

const sortedPosts = await getSortedPosts();
const latestPosts = sortedPosts.slice(0, 2);
---

<Layout title="Pwnissa | CTF Team">
  <link rel="preload" href="/logo-glitch.webp" as="image" type="image/webp" slot="head" />

  <div class="main-content-section">
    <main class="container">
      <div class="bento-grid">
        <LogoTile />
        <AboutTile />
        <MembersTile memberCount={members.length - 2} />
        <BlogTile posts={latestPosts} />
        <PwnyTile />
        <TrainingTile />
        <SupportedByTile />
      </div>
    </main>
  </div>
</Layout>

<style>
  .hidden {
    display: none !important;
  }

  .main-content-section {
    padding: 100px 0 20px;
    background: var(--bg-primary);
    min-height: 100vh;
  }

  /* Bento Box Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(240px, auto);
    gap: 20px;
  }

  /* Shared Card Styles */
  :global(.info-card) {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    border-top: 3px solid var(--accent-teal);
  }

  :global(.card-content) {
    padding: 30px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
  }

  :global(.centered-content) {
    align-items: center;
    text-align: center;
  }

  :global(.info-card h3) {
    font-size: 1.6rem;
    color: var(--text-primary);
    margin-bottom: 15px;
  }

  :global(.info-card p) {
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 20px;
    font-size: 1rem;
  }

  /* Buttons & Links */
  :global(.info-card .cta-button) {
    display: flex;
    width: 100%;
    box-sizing: border-box;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background: var(--bg-primary);
    border: 1px solid var(--card-border);
    border-radius: 4px;
    color: var(--text-primary);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    font-size: 0.9rem;
    text-transform: uppercase;
    transition: all 0.2s ease;
    margin-top: auto;
    outline: none;
    box-shadow: none;
  }

  :global(.info-card .cta-button:hover) {
    border-color: var(--text-secondary);
    box-shadow: none;
    transform: none;
  }

  /* Accent Colors */
  :global(.accent-teal) { border-top-color: var(--accent-teal); }
  :global(.accent-teal .cta-button:hover) { border-color: var(--accent-teal); color: var(--accent-teal); }
  :global(.accent-teal .stat-num) { color: var(--accent-teal); }

  :global(.accent-green) { border-top-color: var(--accent-green); }
  :global(.accent-green .cta-button:hover) { border-color: var(--accent-green); color: var(--accent-green); }

  :global(.accent-gold) { border-top-color: var(--accent-gold); }
  :global(.accent-gold .cta-button:hover) { border-color: var(--accent-gold); color: var(--accent-gold); }

  /* Mobile Responsiveness */
  @media (max-width: 992px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: minmax(200px, auto);
      grid-auto-flow: dense;
    }

    .bento-grid :global(.tile-logo),
    .bento-grid :global(.tile-blog),
    .bento-grid :global(.tile-about),
    .bento-grid :global(.tile-pwny) {
      grid-column: span 2;
    }

    .bento-grid :global(.tile-members),
    .bento-grid :global(.tile-training),
    .bento-grid :global(.tile-supported) {
      grid-column: span 1;
    }
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .bento-grid :global(.tile-logo),
    .bento-grid :global(.tile-blog),
    .bento-grid :global(.tile-about),
    .bento-grid :global(.tile-members),
    .bento-grid :global(.tile-pwny),
    .bento-grid :global(.tile-supported),
    .bento-grid :global(.tile-training) {
      grid-column: span 1;
      grid-row: auto;
    }
  }
</style>
