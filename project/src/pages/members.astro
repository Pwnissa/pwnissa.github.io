---
import Layout from '../layouts/Layout.astro';
import MemberCard from '../components/MemberCard.astro';
import { SITE_TITLE } from '../consts';
import {members} from '../config';


---

<Layout title="Team Members | Pwnissa">

  <div class="team-section">
    <div class="container">
      <div class="team-header">
        <h1>The Team</h1>
        <p>Meet the players, hackers, and developers behind Pwnissa.</p>
      </div>
      <div class="team-grid">
        {members.map(member => (
          <MemberCard 
            nickname={member.nickname}
            name={member.name}
            photo={member.photo}
            tags={member.tags}
            link={member.link}
          />
        ))}
      </div>
      
      <div class="pets-section">
          <h2 class="pets-heading">Our Pets </h2>
          <p class="pets-description">As Colette once said, "<i>Our perfect companions never have fewer than four feet</i> ".<br> Meet our beloved pets who brighten our lives every day!</p>
          <a href="/our-pets" class="cta-button">See Our Pets</a>
      </div>
    </div>
  </div>

  </Layout>

  <style>
  .team-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .team-header h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 20px;
    background: var(--accent-gold);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .team-header p {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .team-section {
    background: var(--bg-primary);
    padding: 100px 0 60px;
    min-height: 100vh;
  }
  .team-note {
    padding: 50px 0;
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: stretch;
  }
  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }

  .pets-section {
    text-align: center;
    padding: 50px 0; /* Add some vertical padding */
    margin-top: 50px; /* Space from the content above */
    border-radius: 15px;
  }

  .pets-heading {
    font-size: 2.2rem; /* Slightly smaller than main H2 */
    color: var(--accent-gold);
    margin-bottom: 20px;
  }

  .pets-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto 40px; /* Center text and add space below */
    line-height: 1.6;
  }



  
  </style>
